# Copy this file to .env and fill in values for local development.
# Each variable is documented when added by the relevant task.

# ── Database ──────────────────────────────────────────────────────────────────
# Added by P1-002 (docker-compose stack)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_agents_observability
# Host port the docker:infra Postgres binds to (container side is always 5432).
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_agents_observability

# ── Object Store (MinIO) ──────────────────────────────────────────────────────
# Added by P1-002
# Prod: replace minioadmin creds with real credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Host ports the docker:infra MinIO binds to (S3 API / web console). Keep
# S3_ENDPOINT below in sync if you change MINIO_PORT.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=transcripts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Added by P1-016
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_HOST=github.com

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Added by P1-014
# JWT_ED25519_PRIVATE_KEY=
# JWT_ED25519_PUBLIC_KEY=

# ── Ingest Service ────────────────────────────────────────────────────────────
# Added by P1-008
INGEST_PORT=4000
GIT_SHA=dev
LOG_LEVEL=info

# ── Web / Next.js ─────────────────────────────────────────────────────────────
# Added by P1-024
WEB_PORT=3000
NEXT_PUBLIC_INGEST_URL=http://localhost:4000

# ── GitHub App ────────────────────────────────────────────────────────────────
# Added by P2-001
# Register a GitHub App at https://github.com/settings/apps/new (or GHES equivalent).
# See docs/github-app-setup.md for full registration instructions.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=      # base64-encoded PEM: base64 -w0 private-key.pem
# GITHUB_APP_WEBHOOK_SECRET=   # openssl rand -hex 32
GITHUB_APP_PORT=4001

# ── GitHub App service ────────────────────────────────────────────────────────
# Added by P2-009
# Optional: if set, GET /admin/health returns extended info (last 10 failures)
# when X-Admin-Secret header matches this value. If absent, basic counters only.
# ADMIN_SECRET=

# ── Hook ──────────────────────────────────────────────────────────────────────
# Added by P1-020
# Overrides ~/.claude-telemetry (queue.db + hook.log + identity.json)
# CLAUDE_TELEMETRY_HOME=

# ── Docker deploy ─────────────────────────────────────────────────────────────
# APP_PORT=3000                # host port for web (set to change the external port)
# APP_IMAGE=ghcr.io/yorch/ai-agents-observability/web:latest  # production image (web)
# DATABASE_URL_OVERRIDE=       # optional: managed DB URL overrides compose service
# DOMAIN_APP=                  # domain for the app (used by Traefik)
# TRAEFIK_NAME=ai-agents-web   # service name label for Traefik
# WATCHTOWER_POLL_INTERVAL=86400  # seconds between watchtower polls
# WATCHTOWER_SCOPE=ai-agents-observability  # scope name for watchtower labeling
