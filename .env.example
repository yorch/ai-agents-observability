# Copy this file to .env and fill in values for local development.
# Each variable is documented when added by the relevant task.

# ── Database ──────────────────────────────────────────────────────────────────
# Added by P1-002 (docker-compose stack)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_agents_observability
# Host port the docker:infra Postgres binds to (container side is always 5432).
POSTGRES_PORT=5432
# localhost is for running apps NATIVELY against docker:infra (the dev workflow).
# The dockerized app stacks (docker:app / docker-compose.prod.yml) ignore this
# and build their own URL from POSTGRES_* against the `postgres` service DNS.
# To point prod at a managed DB instead, set DATABASE_URL_OVERRIDE (see below).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_agents_observability

# ── Object Store (MinIO) ──────────────────────────────────────────────────────
# Added by P1-002
# Prod: replace minioadmin creds with real credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Host ports the docker:infra MinIO binds to (S3 API / web console). Keep
# S3_ENDPOINT below in sync if you change MINIO_PORT.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# localhost is for apps running NATIVELY against docker:infra. The dockerized
# app stacks reach MinIO at http://minio:9000 by default; set
# S3_ENDPOINT_OVERRIDE (see below) to use external S3 in prod.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=transcripts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Added by P1-016
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_HOST=github.com
# Optional single-org gate: when set, device-code login (hook token issuance)
# requires the GitHub user to be a member of this org. Needs read:org scope.
# GITHUB_ALLOWED_ORG=

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Added by P1-014
# JWT_ED25519_PRIVATE_KEY=
# JWT_ED25519_PUBLIC_KEY=

# ── Ingest Service ────────────────────────────────────────────────────────────
# Added by P1-008
INGEST_PORT=4000
GIT_SHA=dev
LOG_LEVEL=info
# Added by P4-007: how long to keep transcript objects in S3/MinIO before deletion.
# 0 = keep forever (no retention enforcement). Default: 365 days.
# TRANSCRIPT_RETENTION_DAYS=365

# ── Web / Next.js ─────────────────────────────────────────────────────────────
# Added by P1-024
WEB_PORT=3000
# Optional: base URL for your Jira instance (no trailing slash).
# When set, Jira keys extracted from PR branch names become clickable links.
# NEXT_PUBLIC_JIRA_BASE_URL=https://your-org.atlassian.net

# ── GitHub App ────────────────────────────────────────────────────────────────
# Added by P2-001
# Register a GitHub App at https://github.com/settings/apps/new (or GHES equivalent).
# See docs/github-app-setup.md for full registration instructions.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=      # base64-encoded PEM: base64 -w0 private-key.pem
# GITHUB_APP_WEBHOOK_SECRET=   # openssl rand -hex 32
GITHUB_APP_PORT=4001

# ── GitHub App service ────────────────────────────────────────────────────────
# Added by P2-009
# Optional: gates GET /admin/health (github-app) and POST /admin/jobs/:name/run
# (ingest). When set, these endpoints require a matching X-Admin-Secret header.
# When unset, the endpoints are DISABLED (404).
# ADMIN_SECRET=

# ── Hook ──────────────────────────────────────────────────────────────────────
# Added by P1-020
# Overrides ~/.claude-telemetry (queue.db + hook.log + identity.json)
# CLAUDE_TELEMETRY_HOME=

# ── Docker deploy ─────────────────────────────────────────────────────────────
# NODE_ENV=production          # runtime mode (development / production)
# WEB_PORT=3000                # host port for web (set to change the external port)
# Image names MUST match the components published by .github/workflows/docker.yml
# (github-app, ingest, migrations-runner, web).
# APP_IMAGE_GITHUB=ghcr.io/yorch/ai-agents-observability/github-app:main  # production image (GitHub app service)
# APP_IMAGE_INGEST=ghcr.io/yorch/ai-agents-observability/ingest:main  # production image (ingest service)
# APP_IMAGE_MIGRATIONS=ghcr.io/yorch/ai-agents-observability/migrations-runner:main  # production image (migrations)
# APP_IMAGE_WEB=ghcr.io/yorch/ai-agents-observability/web:main  # production image (web)
#
# Backend overrides — by default the dockerized app stack talks to the bundled
# postgres + minio services. Set these only to point at managed/external backends:
# DATABASE_URL_OVERRIDE=                    # managed DB URL (replaces bundled postgres)
# S3_ENDPOINT_OVERRIDE=https://s3.amazonaws.com   # external S3 endpoint (replaces bundled minio)
# S3_ACCESS_KEY_ID_OVERRIDE=                # external S3 access key (defaults to MINIO_ROOT_USER)
# S3_SECRET_ACCESS_KEY_OVERRIDE=            # external S3 secret key (defaults to MINIO_ROOT_PASSWORD)
# DOMAIN_APP=                  # domain for the web app (used by Traefik)
# DOMAIN_GITHUB=               # domain for the GitHub app service (used by Traefik)
# TRAEFIK_NAME_GITHUB=ai-agents-github  # service name label for Traefik (GitHub app)
# TRAEFIK_NAME_WEB=ai-agents-web  # service name label for Traefik (web)
# WATCHTOWER_POLL_INTERVAL=86400  # seconds between watchtower polls (default: 86400 = daily)
# WATCHTOWER_SCOPE=ai-agents-observability  # scope name for watchtower labeling
