<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude.telemetry.shipper</string>
  <key>ProgramArguments</key>
  <array>
    <string>__BINARY_PATH__</string>
    <string>shipper</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__TELEMETRY_HOME__/shipper.log</string>
  <key>StandardErrorPath</key>
  <string>__TELEMETRY_HOME__/shipper.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>INGEST_BASE_URL</key>
    <string>__INGEST_BASE_URL__</string>
  </dict>
</dict>
</plist>
