{
  "name": "@ai-agents-observability/hook",
  "version": "0.1.0",
  "private": true,
  "description": "Bun-compiled CLI: claude-telemetry binary",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/claude-telemetry",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64",
    "build:darwin-arm64": "bun build src/cli.ts --compile --target bun-darwin-arm64 --outfile dist/claude-telemetry-darwin-arm64",
    "build:darwin-x64": "bun build src/cli.ts --compile --target bun-darwin-x64 --outfile dist/claude-telemetry-darwin-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --target bun-linux-x64 --outfile dist/claude-telemetry-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target bun-linux-arm64 --outfile dist/claude-telemetry-linux-arm64",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "bench": "bun run bench/hook.bench.ts"
  },
  "dependencies": {
    "@ai-agents-observability/schemas": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "catalog:",
    "typescript": "catalog:"
  }
}
