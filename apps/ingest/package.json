{
  "name": "@ai-agents-observability/ingest",
  "version": "0.0.0",
  "private": true,
  "description": "Ingest API — Bun + Hono. POST /v1/events, /v1/transcripts, /v1/price-table",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-agents-observability/auth": "workspace:*",
    "@ai-agents-observability/db": "workspace:*",
    "@ai-agents-observability/schemas": "workspace:*",
    "@aws-sdk/client-s3": "catalog:",
    "@hono/zod-validator": "catalog:",
    "hono": "catalog:",
    "pino": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "bun-types": "catalog:",
    "pino-pretty": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
