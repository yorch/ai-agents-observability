{
  "name": "@ai-agents-observability/web",
  "version": "0.0.0",
  "private": true,
  "description": "Web dashboard — Next.js. Dashboard + OAuth + read API",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "bun run --env-file=../../.env next dev",
    "build": "NEXT_FONT_GOOGLE_MOCKED_RESPONSES=$(pwd)/src/fonts-mock/google-fonts-mock.js next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ai-agents-observability/auth": "workspace:*",
    "@ai-agents-observability/db": "workspace:*",
    "@ai-agents-observability/github": "workspace:*",
    "@aws-sdk/client-s3": "catalog:",
    "next": "catalog:",
    "pino": "catalog:",
    "prom-client": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "fast-check": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
