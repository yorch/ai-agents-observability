{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "outDir": ".next",
    "paths": {
      "@/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }],
    "rootDir": ".",
    "types": ["bun-types"]
  },
  "exclude": ["node_modules", ".next"],
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*", "next.config.ts", "next-env.d.ts"]
}
