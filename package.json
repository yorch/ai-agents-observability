{
  "name": "ai-agents-observability",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hosted observability platform for AI coding agents",
  "license": "FSL-1.1-MIT",
  "author": "Jorge Barnaby",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14",
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:ingest": "bun run --cwd apps/ingest dev",
    "dev:github-app": "bun run --cwd apps/github-app dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "biome check --error-on-warnings .",
    "lint": "bun run check",
    "lint:fix": "bun run check --write .",
    "format": "biome format --write .",
    "gen:keys": "bun run --cwd packages/auth gen:keys",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:deploy": "bun run --cwd packages/db db:deploy",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:reset": "bun run --cwd packages/db db:reset",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:seed": "bun run --cwd packages/db db:seed",
    "db:seed:extensive": "bun run --cwd packages/db db:seed --extensive",
    "docker:infra": "docker compose -f docker-compose.infra.yml",
    "docker:infra:up": "bun run docker:infra up -d",
    "docker:infra:down": "bun run docker:infra down",
    "docker:infra:down:v": "bun run docker:infra down -v",
    "docker:infra:logs": "bun run docker:infra logs -f",
    "docker:app": "docker compose -f docker-compose.app.yml -f docker-compose.infra.yml",
    "docker:app:up": "bun run docker:app up -d",
    "docker:app:down": "bun run docker:app down",
    "docker:app:build": "bun run docker:app build",
    "docker:app:logs": "bun run docker:app logs -f"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@aws-sdk/client-s3": "3.1089.0",
      "bun-types": "1.3.14",
      "@biomejs/biome": "2.5.4",
      "@hono/zod-validator": "0.9.0",
      "@octokit/plugin-enterprise-compatibility": "6.0.3",
      "@octokit/webhooks": "14.2.0",
      "@tailwindcss/postcss": "4.3.3",
      "croner": "10.0.1",
      "fast-check": "4.9.0",
      "hono": "4.12.30",
      "jose": "6.2.3",
      "keytar": "7.9.0",
      "next": "16.2.10",
      "nodemailer": "9.0.3",
      "@types/nodemailer": "8.0.1",
      "octokit": "5.0.5",
      "pino": "10.3.1",
      "pino-pretty": "13.1.3",
      "@prisma/adapter-pg": "7.8.0",
      "@prisma/client": "7.8.0",
      "prisma": "7.8.0",
      "react": "19.2.7",
      "react-dom": "19.2.7",
      "react-virtuoso": "4.18.11",
      "tailwindcss": "4.3.3",
      "turbo": "2.10.5",
      "typescript": "6.0.3",
      "vitest": "4.1.10",
      "zod": "4.4.3",
      "@faker-js/faker": "10.5.0",
      "js-yaml": "5.2.1",
      "prom-client": "15.1.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
