{
  "name": "ai-agents-observability",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hosted observability platform for AI coding agents",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": "1.3.13",
    "node": ">=24"
  },
  "scripts": {
    "check": "biome check --error-on-warnings .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "docker:infra": "docker compose -f infra/docker-compose.yml",
    "docker:infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:infra:down": "docker compose -f infra/docker-compose.yml down",
    "docker:infra:down:v": "docker compose -f infra/docker-compose.yml down -v",
    "docker:infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@aws-sdk/client-s3": "3.1047.0",
      "bun-types": "1.2.0",
      "@biomejs/biome": "2.4.0",
      "@hono/zod-validator": "0.4.3",
      "@octokit/plugin-enterprise-compatibility": "4.0.1",
      "@octokit/webhooks": "14.1.0",
      "@tailwindcss/postcss": "4.1.0",
      "croner": "10.0.1",
      "fast-check": "4.4.0",
      "hono": "4.12.19",
      "jose": "6.2.3",
      "keytar": "7.9.0",
      "next": "16.2.0",
      "octokit": "5.0.5",
      "pino": "10.3.1",
      "pino-pretty": "13.1.3",
      "pino-roll": "4.0.0",
      "@prisma/adapter-pg": "7.7.0",
      "@prisma/client": "7.7.0",
      "prisma": "7.7.0",
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "react-virtuoso": "4.18.7",
      "tailwindcss": "4.1.0",
      "turbo": "2.9.14",
      "typescript": "6.0.3",
      "vitest": "4.1.6",
      "zod": "4.1.0",
      "@faker-js/faker": "9.8.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
