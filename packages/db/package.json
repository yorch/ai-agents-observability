{
  "name": "@ai-agents-observability/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema + migrations + Timescale SQL + Prisma client export",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "PRISMA_SCHEMA_ENGINE_BINARY=$(pwd)/scripts/fake-schema-engine.sh PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "bun run --env-file=../../.env prisma migrate dev",
    "db:push": "bun run --env-file=../../.env prisma db push",
    "db:reset": "bun run --env-file=../../.env prisma migrate reset",
    "db:studio": "bun run --env-file=../../.env prisma studio",
    "db:deploy": "bun --env-file=../../.env run src/deploy.ts",
    "db:seed": "bun --env-file=../../.env run src/seed.ts",
    "db:seed:extensive": "bun --env-file=../../.env run src/seed.ts --extensive"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "prisma": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
