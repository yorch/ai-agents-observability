{
  "name": "@ai-agents-observability/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema + migrations + Timescale SQL + Prisma client export",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "bun run src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "prisma": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
