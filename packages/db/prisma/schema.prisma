generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum SessionStatus {
  ACTIVE
  COMPLETED
  CRASHED
  TIMED_OUT
  ABANDONED
}

enum AgentType {
  CLAUDE_CODE
  CURSOR
  AIDER
  COPILOT
  CODEX
  WINDSURF
  OPENCODE
}

enum AuditAction {
  VIEW_SESSION
  VIEW_TRANSCRIPT
  EXPORT_TEAM
  EXPORT_ORG
  ADMIN_IMPERSONATE
  DELETE_REQUEST
  HOOK_TOKEN_ISSUED
  ROLE_GRANT
  RETENTION_OVERRIDE_CHANGED
  GRANT_REQUESTED
  GRANT_APPROVED
  GRANT_REVOKED
  ALERT_ACKNOWLEDGED
  ALERT_SILENCED
}

enum GrantScope {
  USER_SESSIONS
  SINGLE_SESSION
}

enum AuthTokenKind {
  ACCESS
  REFRESH
  HOOK
}

enum TeamRole {
  MEMBER
  LEAD
  MAINTAINER
}

enum OrgRole {
  MEMBER
  ORG_ADMIN
  VIEWER_AGGREGATE
  // Audience-B researcher (P9-005). Aggregate access like VIEWER_AGGREGATE PLUS
  // the ability to REQUEST time-boxed grants — never standing individual access.
  INVESTIGATOR
}

enum PRState {
  OPEN
  CLOSED
  MERGED
}

enum LinkSource {
  SESSION_START
  WEBHOOK_RECONCILE
  MANUAL
}

// ── Dimension tables ─────────────────────────────────────────────────────────

model Team {
  id           String   @id @default(uuid()) @db.Uuid
  githubSlug   String   @unique @map("github_slug")
  githubId     BigInt   @unique @map("github_id")
  name         String
  parentTeamId String?  @map("parent_team_id") @db.Uuid
  syncedAt     DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)
  // Per-team transcript retention override (P9-004). null = use global default.
  retentionDays Int?    @map("retention_days")

  parentTeam   Team?        @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  childTeams   Team[]       @relation("TeamHierarchy")
  members      TeamMember[]
  primaryUsers User[]       @relation("UserPrimaryTeam")
  repos        Repo[]
  auditLogs    AuditLog[]
  sessions     Session[]

  @@map("teams")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  githubLogin   String?   @unique @map("github_login")
  githubId      BigInt?   @unique @map("github_id")
  email         String?   @unique
  passwordHash  String?   @map("password_hash")
  displayName   String?   @map("display_name")
  primaryTeamId String?   @map("primary_team_id") @db.Uuid
  orgRole       OrgRole   @default(MEMBER) @map("org_role")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt    DateTime? @map("last_seen_at") @db.Timestamptz(6)
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz(6)

  primaryTeam       Team?             @relation("UserPrimaryTeam", fields: [primaryTeamId], references: [id])
  teamMemberships   TeamMember[]
  sessions          Session[]
  authTokens        AuthToken[]
  visibilityPolicy  VisibilityPolicy?
  actorAuditLogs    AuditLog[]        @relation("AuditActor")
  targetAuditLogs   AuditLog[]        @relation("AuditTarget")
  pullRequests      PullRequest[]
  deletionRequests  DeletionRequest[]
  accessGrants      AccessGrant[]     @relation("GrantGrantee")

  @@index([lastSeenAt])
  @@map("users")
}

model TeamMember {
  teamId     String    @map("team_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  roleInTeam TeamRole  @map("role_in_team")
  syncedAt   DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)
  leftAt     DateTime? @map("left_at") @db.Timestamptz(6)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model Repo {
  id            String   @id @default(uuid()) @db.Uuid
  githubOwner   String   @map("github_owner")
  githubName    String   @map("github_name")
  githubId      BigInt?  @unique @map("github_id")
  defaultBranch String?  @map("default_branch")
  owningTeamId  String?  @map("owning_team_id") @db.Uuid
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)

  owningTeam   Team?               @relation(fields: [owningTeamId], references: [id])
  sessions     Session[]
  pullRequests PullRequest[]
  commitLinks  SessionCommitLink[]

  @@unique([githubOwner, githubName])
  @@map("repos")
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model AuthToken {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  tokenHash String        @map("token_hash")
  kind      AuthTokenKind
  expiresAt DateTime?     @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime?     @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("auth_tokens")
}

// ── Privacy & audit ───────────────────────────────────────────────────────────

model VisibilityPolicy {
  userId                    String   @id @map("user_id") @db.Uuid
  shareMetadataWithTeam     Boolean  @default(true) @map("share_metadata_with_team")
  shareMetadataWithOrg      Boolean  @default(true) @map("share_metadata_with_org")
  shareTranscriptsWithTeam  Boolean  @default(false) @map("share_transcripts_with_team")
  shareTranscriptsWithOrg   Boolean  @default(false) @map("share_transcripts_with_org")
  updatedAt                 DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("visibility_policies")
}

model AuditLog {
  id              BigInt      @id @default(autoincrement())
  ts              DateTime    @default(now()) @db.Timestamptz(6)
  actorUserId     String      @map("actor_user_id") @db.Uuid
  action          AuditAction
  targetUserId    String?     @map("target_user_id") @db.Uuid
  targetSessionId String?     @map("target_session_id") @db.Uuid
  targetTeamId    String?     @map("target_team_id") @db.Uuid
  justification   String?
  ip              String?
  userAgent       String?     @map("user_agent")

  actor      User  @relation("AuditActor", fields: [actorUserId], references: [id])
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id])
  targetTeam Team? @relation(fields: [targetTeamId], references: [id])

  @@index([targetUserId, ts(sort: Desc)])
  @@index([actorUserId, ts(sort: Desc)])
  @@map("audit_log")
}

// ── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  sessionId            String        @id @map("session_id") @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  agentType            AgentType     @default(CLAUDE_CODE) @map("agent_type")
  agentVersion         String?       @map("agent_version")
  startedAt            DateTime      @map("started_at") @db.Timestamptz(6)
  endedAt              DateTime?     @map("ended_at") @db.Timestamptz(6)
  lastEventAt          DateTime      @map("last_event_at") @db.Timestamptz(6)
  status               SessionStatus
  endReason            String?       @map("end_reason")
  isResume             Boolean       @default(false) @map("is_resume")
  resumedFromSessionId String?       @map("resumed_from_session_id") @db.Uuid
  compactionCount      Int           @default(0) @map("compaction_count")
  clearCount           Int           @default(0) @map("clear_count")
  hostHash             String?       @map("host_hash")
  claudeCodeVersion    String?       @map("claude_code_version")
  os                   String?
  cwd                  String?
  repoId               String?       @map("repo_id") @db.Uuid
  gitBranch            String?       @map("git_branch")
  gitCommit            String?       @map("git_commit")
  gitRemoteUrl         String?       @map("git_remote_url")
  gitIsDirty           Boolean?      @map("git_is_dirty")
  prNumber             Int?          @map("pr_number")
  prCiStatus           String?       @map("pr_ci_status")
  prReviewDecision     String?       @map("pr_review_decision")
  githubLogin          String?       @map("github_login")
  githubTeam           String?       @map("github_team")
  // Resolved Team FK for github_team (hook reports the team *name*; resolved at
  // ingest only when exactly one synced team matches — ambiguous names stay null).
  teamId               String?       @map("team_id") @db.Uuid
  projectName          String?       @map("project_name")
  // Jira issue key extracted from git_branch at ingest (e.g. PROJ-123) — gives
  // ticket attribution even for sessions that never produce a PR.
  jiraKey              String?       @map("jira_key")

  // Human-in-the-loop: representative permission/autonomy mode for the session —
  // the least-supervised (most autonomous) mode observed across its events.
  mode                 String?       @map("mode")

  totalInputTokens      BigInt  @default(0) @map("total_input_tokens")
  totalOutputTokens     BigInt  @default(0) @map("total_output_tokens")
  totalCacheRead        BigInt  @default(0) @map("total_cache_read")
  totalCacheCreation    BigInt  @default(0) @map("total_cache_creation")
  totalCostUsd          Decimal @default(0) @map("total_cost_usd") @db.Decimal(12, 6)
  toolCallCount         Int     @default(0) @map("tool_call_count")
  toolErrorCount        Int     @default(0) @map("tool_error_count")
  permissionPromptCount Int     @default(0) @map("permission_prompt_count")
  permissionDenyCount   Int     @default(0) @map("permission_deny_count")
  interruptCount        Int     @default(0) @map("interrupt_count")
  userMessageCount      Int     @default(0) @map("user_message_count")
  // Human-in-the-loop: count of Notification events where the agent stopped to
  // get the human's attention (permission / idle / elicitation prompts).
  notificationCount     Int     @default(0) @map("notification_count")
  primaryModel          String? @map("primary_model")

  transcriptS3Key      String?   @map("transcript_s3_key")
  transcriptBytes      BigInt?   @map("transcript_bytes")
  transcriptUploadedAt DateTime? @map("transcript_uploaded_at") @db.Timestamptz(6)
  transcriptRedacted   Boolean   @default(false) @map("transcript_redacted")
  // Redaction classes matched in the shipped transcript (e.g. aws_key, github_pat,
  // jwt, private_key) — computed at ship time but previously only logged, never
  // persisted. Empty by default; not backfilled for transcripts shipped before
  // this column existed.
  redactionFlags       String[]  @default([]) @map("redaction_flags")

  shapeLabel           String?   @map("shape_label")
  frictionScore        Float?    @map("friction_score")

  // Human-in-the-loop response latency: total time (ms) the agent waited at
  // blocking notifications and the number of such samples, derived nightly by
  // compute-effectiveness. Mean response time = total_response_ms / sample_count.
  totalResponseMs      BigInt    @default(0) @map("total_response_ms")
  responseSampleCount  Int       @default(0) @map("response_sample_count")

  user        User                @relation(fields: [userId], references: [id])
  repo        Repo?               @relation(fields: [repoId], references: [id])
  team        Team?               @relation(fields: [teamId], references: [id])
  prLinks     SessionPRLink[]
  commitLinks SessionCommitLink[]

  @@index([userId, startedAt(sort: Desc)])
  @@index([repoId, startedAt(sort: Desc)])
  @@index([status, lastEventAt])
  @@index([agentType, startedAt(sort: Desc)])
  @@index([jiraKey])
  @@map("sessions")
}

// ── Pull requests ─────────────────────────────────────────────────────────────

model PullRequest {
  repoId            String    @map("repo_id") @db.Uuid
  prNumber          Int       @map("pr_number")
  githubId          BigInt    @unique @map("github_id")
  title             String?
  authorUserId      String?   @map("author_user_id") @db.Uuid
  authorGithubLogin String    @map("author_github_login")
  state             PRState
  baseBranch        String?   @map("base_branch")
  headBranch        String?   @map("head_branch")
  openedAt          DateTime? @map("opened_at") @db.Timestamptz(6)
  closedAt          DateTime? @map("closed_at") @db.Timestamptz(6)
  mergedAt          DateTime? @map("merged_at") @db.Timestamptz(6)
  linesAdded        Int?      @map("lines_added")
  linesRemoved      Int?      @map("lines_removed")
  filesChanged      Int?      @map("files_changed")
  reviewCount       Int?      @map("review_count")
  reviewerLogins      String[]  @map("reviewer_logins")
  labels              String[]
  enrichedAt          DateTime  @default(now()) @map("enriched_at") @db.Timestamptz(6)
  // P5-003: revert detection — set when a reverting PR is merged
  revertedAt          DateTime? @map("reverted_at") @db.Timestamptz(6)
  // P5-003: on the reverting PR, points back to the PR it reverts
  revertOfPrNumber    Int?      @map("revert_of_pr_number")
  // P5-004: Jira issue key extracted from head branch name (e.g. PROJ-123)
  jiraKey             String?   @map("jira_key")
  isDraft             Boolean?  @map("is_draft")

  repo       Repo          @relation(fields: [repoId], references: [id], onDelete: Cascade)
  authorUser User?         @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  prLinks    SessionPRLink[]
  rollup     PRRollup?
  checkRuns  PRCheckRun[]
  reviews    PRReview[]

  @@id([repoId, prNumber])
  // ROI/delivery dashboards range-scan PRs by open/merge date over a window.
  @@index([openedAt])
  @@index([mergedAt])
  // Jira joins (spend-by-key, jira_issues enrichment) look PRs up by key.
  @@index([jiraKey])
  @@map("pull_requests")
}

// Per-check-run outcome history (extends P5-005's failure counter). One row per
// (check run, PR) — a check_run webhook can reference several PRs in its repo.
// Upserted on github_id + pr_number so queued→completed transitions update in place.
model PRCheckRun {
  id          BigInt    @id @default(autoincrement())
  repoId      String    @map("repo_id") @db.Uuid
  prNumber    Int       @map("pr_number")
  githubId    BigInt    @map("github_id")
  name        String
  status      String
  conclusion  String?
  headSha     String?   @map("head_sha")
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)

  pullRequest PullRequest @relation(fields: [repoId, prNumber], references: [repoId, prNumber], onDelete: Cascade)

  @@unique([repoId, prNumber, githubId])
  @@index([repoId, prNumber, completedAt])
  @@map("pr_check_runs")
}

// Submitted PR reviews (pull_request_review webhook) — review latency and
// review-burden signals. review_count on pull_requests is maintained from these rows.
model PRReview {
  id            BigInt    @id @default(autoincrement())
  repoId        String    @map("repo_id") @db.Uuid
  prNumber      Int       @map("pr_number")
  githubId      BigInt    @unique @map("github_id")
  reviewerLogin String    @map("reviewer_login")
  state         String
  submittedAt   DateTime? @map("submitted_at") @db.Timestamptz(6)

  pullRequest PullRequest @relation(fields: [repoId, prNumber], references: [repoId, prNumber], onDelete: Cascade)

  @@index([repoId, prNumber])
  @@map("pr_reviews")
}

// Commit→session correlation from default-branch push webhooks (DESIGN_DOC §7.2):
// a pushed commit is attributed to a session when the repo matches, the commit
// author's login matches the session's github_login, and the commit timestamp
// falls inside the session's activity window (plus a post-session grace period).
model SessionCommitLink {
  sessionId   String    @map("session_id") @db.Uuid
  repoId      String    @map("repo_id") @db.Uuid
  commitSha   String    @map("commit_sha")
  authorLogin String?   @map("author_login")
  committedAt DateTime? @map("committed_at") @db.Timestamptz(6)
  linkedAt    DateTime  @default(now()) @map("linked_at") @db.Timestamptz(6)

  session Session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  repo    Repo    @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@id([sessionId, repoId, commitSha])
  @@index([repoId, commitSha])
  // The ROI merged-work-provenance query range-scans by commit time.
  @@index([committedAt])
  @@map("session_commit_links")
}

// ── Jira (P5-004 follow-up: full integration) ────────────────────────────────

// Issue metadata synced from the Jira REST API by the env-gated `sync-jira` job.
// `key` is referenced by pull_requests.jira_key / sessions.jira_key as a plain
// string (no FK) — keys are extracted before the issue is ever synced.
model JiraIssue {
  key         String    @id
  summary     String?
  issueType   String?   @map("issue_type")
  status      String?
  epicKey     String?   @map("epic_key")
  // Project: key is also the issue-key prefix (PLAT-123 → PLAT) but stored
  // explicitly for indexed grouping; name is display-only and API-sourced
  // ("Platform Engineering") — not derivable from the key.
  projectKey  String?   @map("project_key")
  projectName String?   @map("project_name")
  storyPoints Float?    @map("story_points")
  // Optional per-issue business value (currency units), synced from a Jira
  // custom field (JIRA_VALUE_FIELD). Enables a true external business-value
  // join on /org/roi instead of the flat VALUE_PER_STORY_POINT proxy.
  businessValue Float?  @map("business_value")
  assignee    String?
  // Jira's own created date — enables post-merge-defect windows.
  issueCreatedAt DateTime? @map("issue_created_at") @db.Timestamptz(6)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)
  syncedAt    DateTime  @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@index([epicKey])
  @@index([issueType])
  @@index([projectKey])
  @@map("jira_issues")
}

// Issue-to-issue links from the Jira API (issuelinks), snapshotted per synced
// issue. `description` is the relation phrase from the source's perspective
// ("is caused by", "relates to", …) — surfaced verbatim so defect attribution
// reports linkage and lets humans judge causation. Keys are plain strings (no
// FK): either endpoint may not be synced yet.
model JiraIssueLink {
  sourceKey   String   @map("source_key")
  targetKey   String   @map("target_key")
  linkType    String   @map("link_type")
  description String?
  syncedAt    DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  @@id([sourceKey, targetKey, linkType])
  @@index([targetKey])
  @@map("jira_issue_links")
}

model SessionPRLink {
  sessionId  String     @map("session_id") @db.Uuid
  repoId     String     @map("repo_id") @db.Uuid
  prNumber   Int        @map("pr_number")
  linkedAt   DateTime   @default(now()) @map("linked_at") @db.Timestamptz(6)
  linkSource LinkSource @map("link_source")

  session     Session     @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  pullRequest PullRequest @relation(fields: [repoId, prNumber], references: [repoId, prNumber], onDelete: Cascade)

  @@id([sessionId, repoId, prNumber])
  @@index([repoId, prNumber])
  @@map("session_pr_links")
}

model PRRollup {
  repoId                 String    @map("repo_id") @db.Uuid
  prNumber               Int       @map("pr_number")
  contributingUserIds    String[]  @map("contributing_user_ids")
  contributingSessionIds String[]  @map("contributing_session_ids")
  firstSessionAt         DateTime? @map("first_session_at") @db.Timestamptz(6)
  lastSessionAt          DateTime? @map("last_session_at") @db.Timestamptz(6)
  totalActiveSeconds     Int?      @map("total_active_seconds")
  totalCostUsd           Decimal?  @map("total_cost_usd") @db.Decimal(12, 6)
  totalInputTokens       BigInt?   @map("total_input_tokens")
  totalOutputTokens      BigInt?   @map("total_output_tokens")
  totalToolCalls         Int?      @map("total_tool_calls")
  totalToolErrors        Int?      @map("total_tool_errors")
  totalPermissionDenies  Int?      @map("total_permission_denies")
  costPerLoc             Decimal?  @map("cost_per_loc") @db.Decimal(12, 6)
  // P5-005: cumulative count of failed check runs on associated PR
  checkFailuresCount     Int       @default(0) @map("check_failures_count")
  computedAt             DateTime  @default(now()) @map("computed_at") @db.Timestamptz(6)

  pullRequest PullRequest @relation(fields: [repoId, prNumber], references: [repoId, prNumber], onDelete: Cascade)

  @@id([repoId, prNumber])
  @@map("pr_rollups")
}

// ── Jobs ──────────────────────────────────────────────────────────────────────

model JobRun {
  id         BigInt    @id @default(autoincrement())
  jobName    String    @map("job_name")
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt DateTime? @map("finished_at") @db.Timestamptz(6)
  status     String    @default("running")
  errorText  String?   @map("error_text")

  @@index([jobName, startedAt(sort: Desc)])
  @@map("job_runs")
}

// ── GDPR / Deletion ───────────────────────────────────────────────────────────

model DeletionRequest {
  id          BigInt    @id @default(autoincrement())
  userId      String    @map("user_id") @db.Uuid
  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  reason      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("deletion_requests")
}

// ── Webhook deliveries ────────────────────────────────────────────────────────

model WebhookDelivery {
  id           BigInt    @id @default(autoincrement())
  deliveryId   String    @unique @map("delivery_id")
  eventType    String    @map("event_type")
  action       String?
  repo         String?
  receivedAt   DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt  DateTime? @map("processed_at") @db.Timestamptz(6)
  status       String
  errorText    String?   @map("error_text")

  @@index([eventType, receivedAt(sort: Desc)])
  @@index([receivedAt(sort: Desc)])
  @@map("webhook_deliveries")
}

// ── Job config (UI-configurable schedules) ────────────────────────────────────

model JobConfig {
  jobName        String    @id @map("job_name")
  enabled        Boolean   @default(true)
  runHourUtc     Int       @map("run_hour_utc")    @db.SmallInt
  runMinuteUtc   Int       @map("run_minute_utc")  @db.SmallInt
  runRequestedAt DateTime? @map("run_requested_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("job_config")
}

// ── Alerting (P9-001) ─────────────────────────────────────────────────────────

model AlertRule {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  ruleType       String   @map("rule_type")
  params         Json     @default("{}")
  enabled        Boolean  @default(true)
  cadenceMinutes Int      @default(60) @map("cadence_minutes")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // R7 (HITL): when set and in the future, the rule is evaluated but suppressed —
  // it neither fires nor notifies until this time. Guards against alert fatigue.
  silencedUntil  DateTime? @map("silenced_until") @db.Timestamptz(6)

  events AlertEvent[]

  @@index([enabled])
  @@map("alert_rules")
}

// ── Access grants (P9-003) ────────────────────────────────────────────────────

// Time-boxed, scoped, audited transcript access (DESIGN_DOC §8.4). Replaces
// implicit standing org-admin reach: access to a non-sharing user's transcript
// requires an approved, non-expired, non-revoked grant whose scope covers the target.
model AccessGrant {
  id              String     @id @default(uuid()) @db.Uuid
  granteeUserId   String     @map("grantee_user_id") @db.Uuid
  // target_user_id / target_session_id are plain UUIDs (not Prisma relations) to
  // avoid extra User back-relations; resolved on read where needed.
  targetUserId    String?    @map("target_user_id") @db.Uuid
  targetSessionId String?    @map("target_session_id") @db.Uuid
  scope           GrantScope
  justification   String
  grantedByUserId String?    @map("granted_by_user_id") @db.Uuid
  requestedAt     DateTime   @default(now()) @map("requested_at") @db.Timestamptz(6)
  grantedAt       DateTime?  @map("granted_at") @db.Timestamptz(6)
  expiresAt       DateTime?  @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime?  @map("revoked_at") @db.Timestamptz(6)

  grantee User @relation("GrantGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)

  @@index([granteeUserId, expiresAt])
  @@index([grantedAt, revokedAt])
  @@map("access_grants")
}

// R11 (HITL feedback): a lightweight human signal on a session — was the agent's
// work actually good? The ground truth that calibrates friction/autonomy signals.
// session_id / user_id are plain UUIDs (not relations), matching the AccessGrant
// pattern, to avoid extra back-relations. One row per (session, user).
model SessionFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sentiment String
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@map("session_feedback")
}

model AlertEvent {
  id         BigInt    @id @default(autoincrement())
  ruleId     String    @map("rule_id") @db.Uuid
  firedAt    DateTime  @default(now()) @map("fired_at") @db.Timestamptz(6)
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz(6)
  severity   String
  details    Json      @default("{}")
  // R7 (HITL): an admin acknowledged this firing ("seen it"). Distinct from
  // resolved (the condition cleared) — acknowledgement is a human action.
  acknowledgedAt       DateTime? @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedByUserId String?   @map("acknowledged_by_user_id") @db.Uuid

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  // One open (unresolved) event per rule — the firing/resolving transition is
  // recorded once. Enforced in the job; the index speeds the open-event lookup.
  @@index([ruleId, resolvedAt])
  @@map("alert_events")
}

// Org-level notification channels (P9-002). Runtime-editable (no redeploy).
model AlertChannelConfig {
  id          String   @id @default(uuid()) @db.Uuid
  channelType String   @map("channel_type")
  config      Json     @default("{}")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("alert_channel_config")
}

// Per-attempt delivery outcome (P9-002). Surfaces persistent failures in the UI.
model AlertDeliveryLog {
  id          BigInt   @id @default(autoincrement())
  channelType String   @map("channel_type")
  attemptedAt DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)
  success     Boolean
  error       String?

  @@index([attemptedAt(sort: Desc)])
  @@map("alert_delivery_log")
}
