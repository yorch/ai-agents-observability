{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "GITHUB_HOST",
        "GITHUB_OAUTH_CLIENT_ID",
        "GITHUB_OAUTH_CLIENT_SECRET",
        "NODE_ENV"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "src/generated/**"]
    },
    "check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build", "^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["build", "^typecheck"],
      "outputs": ["*.tsbuildinfo"]
    }
  },
  "ui": "tui"
}
